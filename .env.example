# Direct Gemini API key — required for Search-grounded noun harvesting (lore auto-fetching)
# Get one at https://aistudio.google.com/app/apikey
MY_GEMINI_API_KEY=

# Google Cloud project ID — required for Vertex AI (story gen, image gen, embeddings)
# Create a project at https://console.cloud.google.com and enable the Vertex AI API
GOOGLE_CLOUD_PROJECT=

# Path to Application Default Credentials
# Run: gcloud auth application-default login
# Then point this at the file it creates (usually ~/.config/gcloud/application_default_credentials.json)
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: override the Gemini model for story generation (default: gemini-2.5-flash)
GEMINI_MODEL=

# App base URL — leave as-is for local dev; change for deployed environments
APP_URL=http://localhost:3000
